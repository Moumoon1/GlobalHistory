{
  "name": "history-globe",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "db:build": "node scripts/build-history-db.mjs",
    "db:import:cards": "node scripts/import-learning-cards.mjs",
    "cards:merge:v2": "node scripts/merge-learning-cards.mjs data/generated/learning-cards.json data/curation/global-history-v2-chapter1-2.json ../../outputs/global-history-learning-cards-v2.json",
    "cards:build:v2": "node scripts/build-v2-learning-cards.mjs",
    "cards:audit": "node scripts/audit-learning-cards.mjs",
    "preview": "vite preview",
    "lint": "eslint ."
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-globe.gl": "^2.33.0",
    "three": "^0.178.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/geojson": "^7946.0.16",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.184.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.0.0",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.17"
  }
}
